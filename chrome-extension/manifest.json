{
  "manifest_version": 3,
  "name": "Dugg This",
  "version": "1.1.0",
  "description": "Save, discover, and share links across your Dugg servers.",

  "permissions": ["activeTab", "storage", "scripting", "alarms"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/dugg-16.png",
      "48": "icons/dugg-48.png",
      "128": "icons/dugg-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/dugg-16.png",
    "48": "icons/dugg-48.png",
    "128": "icons/dugg-128.png"
  }
}
