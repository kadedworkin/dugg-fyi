{
  "manifest_version": 3,
  "name": "Dugg This",
  "version": "1.0.0",
  "description": "Send the current page to your Dugg agent for enrichment and publication.",

  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/dugg-16.png",
      "48": "icons/dugg-48.png",
      "128": "icons/dugg-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/dugg-16.png",
    "48": "icons/dugg-48.png",
    "128": "icons/dugg-128.png"
  }
}
